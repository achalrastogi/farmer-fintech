# ─── Database (RDS PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fintech:fintech123@localhost:5432/farmerfintech

# ─── Cache (ElastiCache Redis) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AWS Credentials ──────────────────────────────────────────────────────────
# In production: stored in AWS Secrets Manager, injected by ECS task role
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1

# ─── AWS Bedrock ──────────────────────────────────────────────────────────────
# Enable: AWS Console → Bedrock → Model access → Claude 3 Sonnet (ap-south-1)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MOCK_MODE=true

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
S3_CONTENT_BUCKET=farmer-fintech-content
S3_SYNC_BUCKET=farmer-fintech-sync

# ─── AWS DynamoDB ─────────────────────────────────────────────────────────────
DYNAMO_GAME_SESSIONS_TABLE=FintechGameSessions
DYNAMO_OFFLINE_SYNC_TABLE=FintechOfflineSyncQueue

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
